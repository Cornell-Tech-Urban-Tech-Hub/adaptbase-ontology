{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Urban Climate Adaptation Solution Extraction Schema v1",
  "description": "Claim-referenced research data structure with three sections: metadata (schema tracking), crawler (seed data from discovery), and dimensions (7 ontology dimensions with claims). Stored as JSONB on solutions.extraction_schema. Claims are first-class objects in the claims table.",
  "type": "object",
  "required": ["metadata", "crawler", "dimensions"],
  "properties": {

    "metadata": {
      "type": "object",
      "description": "Schema version, timestamps, and completeness tracking.",
      "required": ["schema_version", "completeness"],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": ["1.1", "1.2"]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "classification_difficulty_notes": {
          "type": "string",
          "description": "Free text for flagging ambiguous cases. This field drives ontology refinement."
        },
        "completeness": {
          "type": "object",
          "description": "Per-dimension fill rates (0.0 to 1.0). Used by the research agent to identify gaps.",
          "properties": {
            "identity": { "type": "number", "minimum": 0, "maximum": 1 },
            "hazards": { "type": "number", "minimum": 0, "maximum": 1 },
            "urban_systems": { "type": "number", "minimum": 0, "maximum": 1 },
            "mechanisms": { "type": "number", "minimum": 0, "maximum": 1 },
            "implementation": { "type": "number", "minimum": 0, "maximum": 1 },
            "outcomes": { "type": "number", "minimum": 0, "maximum": 1 },
            "context": { "type": "number", "minimum": 0, "maximum": 1 },
            "overall": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },

    "crawler": {
      "type": "object",
      "description": "Initial discovery data from the crawler. This is the researcher's starting point before autonomous research begins.",
      "required": ["city", "quote", "crawl_id"],
      "properties": {
        "city": {
          "type": "string",
          "description": "City name where solution is deployed"
        },
        "country": {
          "type": "string",
          "description": "Country code (ISO 3166-1 alpha-3)"
        },
        "quote": {
          "type": "string",
          "description": "Brief description of the solution from initial discovery"
        },
        "context": {
          "type": "string",
          "description": "Additional context about the solution"
        },
        "category": {
          "type": "string",
          "description": "Primary solution category from crawler classification"
        },
        "subcategory": {
          "type": "string",
          "description": "Solution subcategory from crawler classification"
        },
        "crawl_id": {
          "type": "string",
          "description": "UUID identifying the crawler run that discovered this solution"
        }
      }
    },

    "dimensions": {
      "type": "object",
      "description": "Seven ontology dimensions populated through autonomous research. Each dimension contains claim-referenced data.",
      "required": ["identity", "hazards", "urban_systems", "mechanisms", "implementation", "outcomes", "context"],
      "properties": {

    "identity": {
      "type": "object",
      "description": "What this solution IS — core identification and classification.",
      "properties": {
        "solution_name": { "$ref": "#/$defs/claimed_string" },
        "alternative_names": {
          "type": "array",
          "description": "Other names for the same solution (e.g., CBS, Anshimi, Seoul Safety App).",
          "items": { "type": "string" }
        },
        "solution_description": { "$ref": "#/$defs/claimed_string" },
        "solution_category": {
          "type": "object",
          "description": "Primary taxonomy classification. Values from solution_taxonomy table.",
          "properties": {
            "category_id": { "type": "string" },
            "category_name": { "type": "string" },
            "subcategory_id": { "type": "string" },
            "subcategory_name": { "type": "string" },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "secondary_category": {
          "type": "object",
          "description": "Optional secondary classification for cross-domain solutions.",
          "properties": {
            "category_id": { "type": "string" },
            "category_name": { "type": "string" },
            "subcategory_id": { "type": "string" },
            "subcategory_name": { "type": "string" },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "ipcc_action_type": {
          "type": "object",
          "properties": {
            "values": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["structural_physical", "social", "institutional", "ecosystem_based"]
              }
            },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "implementing_actor_types": {
          "type": "object",
          "properties": {
            "values": {
              "type": "array",
              "description": "Array of actor types involved. Use multiple values instead of 'multi_stakeholder' to preserve specific actor information.",
              "items": {
                "type": "string",
                "enum": [
                  "municipal_government", "regional_government", "national_government",
                  "utility", "private_sector", "ngo", "community", "academic",
                  "international_organization"
                ]
              }
            },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "year_of_deployment": {
          "type": "object",
          "properties": {
            "value": { "type": ["integer", "null"] },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        }
      }
    },

    "hazards": {
      "type": "object",
      "description": "What climate-driven threats this solution addresses. Values from hazards table.",
      "properties": {
        "hazards_addressed": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "hazard_id": {
                "type": "string",
                "description": "Specific hazard ID from vocabularies/hazards.json (e.g., 'coastal_flood', 'heat_wave')"
              },
              "hazard_name": {
                "type": "string",
                "description": "Human-readable hazard name from vocabularies/hazards.json"
              },
              "hazard_category": {
                "type": "string",
                "description": "Hazard category from vocabularies/hazards.json. Valid values: chemical_change, extreme_temperature_cold, extreme_temperature_hot, flood, fog, insects_and_microorganisms, lightning, mass_movement, precipitation, water_scarcity, wave_action, wild_fire, wind"
              },
              "is_primary": { "type": "boolean" },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "resilience_hazards": {
          "type": "array",
          "description": "v1.2: Non-climate shocks and stresses (seismic, cyber, economic, social) that do not map to the C40/Arup climate hazard typology. Used by 100RC and similar sources that treat resilience holistically.",
          "items": {
            "type": "string",
            "description": "Free-text hazard label (e.g., 'Earthquake', 'Cyber Attack', 'Financial Crisis', 'Social Unrest')"
          }
        }
      }
    },

    "urban_systems": {
      "type": "object",
      "description": "What part of the city this solution operates on. Uses hierarchical taxonomy from vocabularies/urban-systems.json.",
      "properties": {
        "systems_affected": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "system_id": {
                "type": "string",
                "description": "Granular system ID from vocabularies/urban-systems.json (e.g., 'substations', 'bioswales', 'high_density_residential')"
              },
              "sector": {
                "type": "string",
                "description": "Top-level sector from vocabularies/urban-systems.json. Valid values: 'built_environment', 'mobility_transport', 'hydrological_water', 'energy_telecom', 'urban_ecology', 'socioeconomic_health', 'governance_finance'"
              },
              "subsector": {
                "type": "string",
                "description": "Subsector from vocabularies/urban-systems.json (e.g., 'energy_transmission', 'stormwater_management')"
              },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        }
      }
    },

    "mechanisms": {
      "type": "object",
      "description": "HOW this solution works. Free text now, cluster later.",
      "properties": {
        "primary_mechanism": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "description": "Free text. Seed vocabulary: absorb, redirect, harden, monitor, govern, shift_risk, adapt_behavior, restore_regenerate"
            },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "secondary_mechanisms": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": { "type": "string" },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "technical_components": {
          "type": "array",
          "description": "Discrete technical components or subsystems.",
          "items": {
            "type": "object",
            "properties": {
              "component": { "type": "string" },
              "description": { "type": "string" },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "resilience_attributes": {
          "type": "array",
          "description": "City Resilience Index attributes this solution embodies. Values from vocabularies/resilience-attributes.json.",
          "items": {
            "type": "object",
            "properties": {
              "attribute_id": { "type": "string", "description": "e.g. 'planning_strategy', 'community_participation'" },
              "attribute_name": { "type": "string" },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        }
      }
    },

    "implementation": {
      "type": "object",
      "description": "Deployment context — cities, scale, timeline, actors, cost.",
      "properties": {
        "cities": {
          "type": "array",
          "description": "Many-to-many: solutions can appear in multiple cities.",
          "items": {
            "type": "object",
            "properties": {
              "city_name": { "type": "string" },
              "country": { "type": "string" },
              "region": { "type": "string" },
              "loc_id": { "type": ["integer", "null"] },
              "deployment_context": { "type": "string" },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "scale_of_deployment": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "enum": ["site", "building", "neighborhood", "district", "city", "regional", "national", "multi_city"]
            },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "implementation_status": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "enum": ["proposed", "scoping", "pilot", "operational", "scaling", "completed"]
            },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "timeline": {
          "type": "object",
          "description": "Project timeline with key dates, milestones, and phases",
          "properties": {
            "base_year": {
              "type": ["integer", "null"],
              "description": "Baseline year for measuring progress (if goal-oriented)"
            },
            "start_year": {
              "type": ["integer", "null"],
              "description": "Year when implementation began"
            },
            "target_year": {
              "type": ["integer", "null"],
              "description": "Target year for completion or achieving goal"
            },
            "end_year": {
              "type": ["integer", "null"],
              "description": "Actual year when completed (if finished)"
            },
            "timeframe_category": {
              "type": "string",
              "description": "CDP timeframe classification: 'short_term' (by 2025), 'medium_term' (2026-2050), 'long_term' (after 2050)"
            },
            "events": {
              "type": "array",
              "description": "Key milestones, phases, and events in the project timeline",
              "items": {
                "type": "object",
                "properties": {
                  "year": { "type": ["integer", "null"] },
                  "date": {
                    "type": "string",
                    "description": "More specific date if known (ISO format: YYYY-MM-DD)"
                  },
                  "event_type": {
                    "type": "string",
                    "description": "Type: 'planning_started', 'funding_secured', 'construction_began', 'pilot_launched', 'operational', 'completion', 'evaluation', 'expansion', 'milestone'"
                  },
                  "description": {
                    "type": "string",
                    "description": "Description of the event or milestone"
                  },
                  "claim_ids": { "$ref": "#/$defs/claim_ids" }
                }
              }
            },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "cost": {
          "type": "object",
          "properties": {
            "cost_range": { "type": "string" },
            "cost_model": { "type": "string" },
            "total_cost_usd": { "type": ["number", "null"] },
            "currency": { "type": "string" },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "financing": {
          "type": "object",
          "description": "Financial structure, funding sources, and investment requirements. Based on CDP project finance fields.",
          "properties": {
            "financing_model": {
              "type": "object",
              "description": "How the project/solution is financed",
              "properties": {
                "value": {
                  "type": "string",
                  "description": "Financing model from vocabularies/enums.json financing_model values (e.g., 'grants', 'public_private_partnership', 'municipal_budget', 'commercial_loans', 'climate_funds')"
                },
                "claim_ids": { "$ref": "#/$defs/claim_ids" }
              }
            },
            "financing_status": {
              "type": "object",
              "description": "Current status of securing funding",
              "properties": {
                "value": {
                  "type": "string",
                  "description": "Status from vocabularies/enums.json financing_status values (e.g., 'fully_funded', 'partially_funded', 'seeking_funding', 'feasibility_stage')"
                },
                "claim_ids": { "$ref": "#/$defs/claim_ids" }
              }
            },
            "funding_sources": {
              "type": "array",
              "description": "Specific sources of funding (can be multiple)",
              "items": {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "description": "Funding source (e.g., 'Municipal budget', 'World Bank', 'Green Climate Fund', 'National government', 'Private sector investment')"
                  },
                  "amount_usd": {
                    "type": ["number", "null"],
                    "description": "Amount from this source in USD (if known)"
                  },
                  "source_type": {
                    "type": "string",
                    "description": "Type of source: 'municipal', 'national', 'international', 'private_sector', 'philanthropic', 'multilateral'"
                  },
                  "claim_ids": { "$ref": "#/$defs/claim_ids" }
                }
              }
            },
            "investment_needed": {
              "type": "object",
              "description": "Total investment required (may differ from actual cost if project is seeking funding)",
              "properties": {
                "amount_usd": { "type": ["number", "null"] },
                "amount_local_currency": { "type": ["number", "null"] },
                "currency": { "type": "string" },
                "claim_ids": { "$ref": "#/$defs/claim_ids" }
              }
            },
            "financial_instruments": {
              "type": "array",
              "description": "Specific financial instruments used (green bonds, sustainability-linked loans, etc.)",
              "items": {
                "type": "object",
                "properties": {
                  "instrument_type": {
                    "type": "string",
                    "description": "Type: 'green_bond', 'sustainability_linked_loan', 'climate_bond', 'resilience_bond', 'blended_finance', 'revolving_fund'"
                  },
                  "amount_usd": { "type": ["number", "null"] },
                  "description": { "type": "string" },
                  "claim_ids": { "$ref": "#/$defs/claim_ids" }
                }
              }
            }
          }
        },
        "key_actors": {
          "type": "array",
          "description": "List multiple actors each with their specific type, rather than using 'multi_stakeholder'.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": [
                  "municipal_government", "regional_government", "national_government",
                  "utility", "private_sector", "ngo", "community", "academic",
                  "international_organization"
                ]
              },
              "role": { "type": "string" },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "suppliers": {
          "type": "array",
          "description": "Vendors, manufacturers, and service providers involved in supplying technology or services for the solution.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": {
                "type": "string",
                "description": "Supplier role (e.g., 'manufacturer', 'system integrator', 'service provider', 'consultant')"
              },
              "component_refs": {
                "type": "array",
                "description": "Optional references to technical components this supplier provides. Values should match 'component' field in technical_components array.",
                "items": { "type": "string" }
              },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        }
      }
    },

    "outcomes": {
      "type": "object",
      "description": "Outcomes, effectiveness, and evaluation quality.",
      "properties": {
        "evidence_level": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "enum": ["anecdotal", "measured", "rigorously_evaluated"]
            },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "outcome_indicators": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "indicator": { "type": "string" },
              "baseline": { "type": "string" },
              "target": { "type": "string" },
              "measured_value": { "type": "string" },
              "unit": { "type": "string" },
              "data_source": { "type": "string" },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "primary_beneficiaries": {
          "type": "object",
          "properties": {
            "values": { "type": "array", "items": { "type": "string" } },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "co_benefits": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "benefit": { "type": "string" },
              "category": {
                "type": "string",
                "enum": ["economic", "public_health", "environmental", "social", "governance", "mitigation"]
              },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "resilience_goals": {
          "type": "array",
          "description": "City Resilience Framework 2024 goals this solution contributes to. Goals from vocabularies/crf-goals.json (e.g., 'crf_goal_01', 'crf_goal_12').",
          "items": {
            "type": "object",
            "properties": {
              "goal_id": {
                "type": "string",
                "description": "Goal ID from vocabularies/crf-goals.json (e.g., 'crf_goal_01' for 'Safe, adequate & affordable housing')"
              },
              "dimension": {
                "type": "string",
                "description": "CRF dimension: 'health_wellbeing', 'economy_society', 'infrastructure_environment', or 'leadership_planning'"
              },
              "contribution_description": {
                "type": "string",
                "description": "How this solution contributes to achieving this resilience goal"
              },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "failure": { "type": "string" },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        }
      }
    },

    "context": {
      "type": "object",
      "description": "Enabling conditions, barriers, governance relationships, and replicability.",
      "properties": {
        "enabling_conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "condition": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["regulatory", "financial", "technical", "social", "institutional"]
              },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "barriers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "barrier": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["regulatory", "financial", "technical", "social", "institutional", "political"]
              },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "replicability": {
          "type": "object",
          "properties": {
            "assessment": { "type": "string" },
            "transferability_factors": { "type": "array", "items": { "type": "string" } },
            "claim_ids": { "$ref": "#/$defs/claim_ids" }
          }
        },
        "governance_relationships": {
          "type": "object",
          "properties": {
            "policies_enabling": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "policy": { "type": "string" },
                  "relationship_type": {
                    "type": "string",
                    "enum": ["MANDATES", "FACILITATED_BY", "ISSUED_BY", "IMPLEMENTS"]
                  },
                  "claim_ids": { "$ref": "#/$defs/claim_ids" }
                }
              }
            },
            "policies_hindering": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "policy": { "type": "string" },
                  "relationship_type": {
                    "type": "string",
                    "enum": ["HINDERED_BY", "CONSTRAINED_BY"]
                  },
                  "claim_ids": { "$ref": "#/$defs/claim_ids" }
                }
              }
            },
            "institutional_arrangements": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "arrangement": { "type": "string" },
                  "claim_ids": { "$ref": "#/$defs/claim_ids" }
                }
              }
            }
          }
        },
        "comparable_implementations": {
          "type": "array",
          "description": "Reference deployments of similar solutions elsewhere.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "city": { "type": "string" },
              "description": { "type": "string" },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        },
        "resilience_frameworks": {
          "type": "array",
          "description": "v1.2: Resilience framework classifications assigned to this solution at import time. Used by 100RC (City Resilience Framework) and similar frameworks that organize solutions by resilience dimensions and drivers.",
          "items": {
            "type": "object",
            "properties": {
              "framework": {
                "type": "string",
                "description": "Short identifier for the framework (e.g., 'CRF')"
              },
              "framework_name": {
                "type": "string",
                "description": "Full name of the framework (e.g., 'City Resilience Framework')"
              },
              "drivers": {
                "type": "array",
                "description": "Framework-specific drivers or sub-dimensions this solution is tagged with",
                "items": { "type": "string" }
              },
              "claim_ids": { "$ref": "#/$defs/claim_ids" }
            }
          }
        }
      }
    }

      }
    }
  },

  "$defs": {
    "claim_ids": {
      "type": "array",
      "description": "References to claim rows in the claims table (claims.id UUIDs).",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },

    "claimed_string": {
      "type": "object",
      "description": "A simple string value with supporting claim references.",
      "properties": {
        "value": { "type": "string" },
        "claim_ids": { "$ref": "#/$defs/claim_ids" }
      }
    }
  }
}
