      "preLaunchTask": "Start editor server"
    },
    {
      "name": "Ontology Viewer (Tailscale)",
      "type": "firefox",
      "request": "launch",
      "url": "http://100.115.183.48:8765/viewer/",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start viewer server (Tailscale)"
    }
  ],
  "compounds": [
    {
      "name": "Viewer + Editor",
      "configurations": ["Ontology Viewer", "Ontology Editor"]
    }
  ]
