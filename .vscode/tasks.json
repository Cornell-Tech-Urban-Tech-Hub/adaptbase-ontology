{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start viewer server",
      "type": "shell",
      "command": "python3 -m http.server 8765 --bind 127.0.0.1",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "label": "Ontology Viewer"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP"
        }
      }
    }
  ]
}
