{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start viewer server",
      "type": "shell",
      "command": "./start-viewer.sh",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "label": "Ontology Viewer"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ctrl-C to stop"
        }
      }
    },
    {
      "label": "Start editor server",
      "type": "shell",
      "command": "./start-editor.sh",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "label": "Ontology Editor"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ctrl-C to stop"
        }
      }
    }
  ]
}
