{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start viewer server",
      "type": "shell",
      "command": "python3 server.py",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "label": "Ontology Viewer"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "POST /save endpoint active"
        }
      }
    }
  ]
}
